---
/**
 * Menú lateral minimalista: navegación fija por secciones con scroll-spy.
 * Se oculta en pantallas estrechas para no pisar el contenido.
 */
const ITEMS = [
  ['apertura', 'inicio'],
  ['fundamento', 'el fundamento'],
  ['sala-lloyd', 'lloyd'],
  ['sala-macqueen', 'macqueen'],
  ['sala-hartigan', 'hartigan-wong'],
  ['sala-elkan', 'elkan'],
  ['sala-fuzzy', 'fuzzy'],
  ['arena', 'la arena'],
  ['guia', 'cuál elijo'],
];
---

<nav class="site-nav" aria-label="Secciones de la página">
  <ol>
    {
      ITEMS.map(([id, label]) => (
        <li>
          <a href={`#${id}`} data-target={id}>
            {label}
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .site-nav {
    position: fixed;
    left: 0;
    top: 50%;
    translate: 0 -50%;
    z-index: 10;
    padding-left: 16px;
  }

  ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 2px;
  }

  a {
    display: block;
    padding: 5px 12px 5px 14px;
    font-size: 0.78rem;
    color: var(--ink-soft);
    text-decoration: none;
    border-left: 2px solid var(--line);
    /* legible aunque la animación de la portada pase por detrás */
    background: var(--bg);
    transition: color 150ms ease, border-color 150ms ease;
  }

  a:hover {
    color: var(--ink);
    border-left-color: var(--ink-soft);
  }

  a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  a[aria-current='true'] {
    color: var(--accent);
    border-left-color: var(--accent);
  }

  @media (max-width: 1180px) {
    .site-nav {
      display: none;
    }
  }
</style>

<script>
  const nav = document.querySelector('.site-nav')!;
  const links = new Map(
    [...nav.querySelectorAll<HTMLAnchorElement>('a')].map((a) => [a.dataset.target!, a]),
  );

  // marca como actual la sección que ocupa la franja central del viewport
  const spy = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        for (const a of links.values()) a.removeAttribute('aria-current');
        links.get(e.target.id)?.setAttribute('aria-current', 'true');
      }
    },
    { rootMargin: '-40% 0px -55% 0px' },
  );

  for (const id of links.keys()) {
    const section = document.getElementById(id);
    if (section) spy.observe(section);
  }

  // Con content-visibility:auto las alturas de las secciones lejanas son
  // estimadas y el scroll a un ancla puede quedarse corto. Este manejador
  // (para el menú y para cualquier enlace interno, como los de la guía)
  // hace el scroll y corrige el destino cuando el layout se asienta.
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.addEventListener('click', (ev) => {
    const a = (ev.target as HTMLElement).closest<HTMLAnchorElement>('a[href^="#"]');
    if (!a) return;
    const el = document.getElementById(a.getAttribute('href')!.slice(1));
    if (!el) return;
    ev.preventDefault();
    history.pushState(null, '', a.getAttribute('href'));
    el.scrollIntoView({ behavior: reduced ? 'instant' : 'smooth', block: 'start' });
    const settle = () => {
      if (Math.abs(el.getBoundingClientRect().top) > 8) {
        el.scrollIntoView({ behavior: 'instant', block: 'start' });
      }
    };
    if ('onscrollend' in window) {
      addEventListener('scrollend', settle, { once: true });
    } else {
      setTimeout(settle, 900);
    }
    setTimeout(settle, 1600); // segunda corrección por si el asentamiento llega tarde
  });
</script>
