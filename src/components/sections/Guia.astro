---
/**
 * Sección 4 — La guía de decisión. Tabla comparativa de las cinco variantes,
 * basada en el resumen del Tema 3: cómo actualiza cada una los centroides,
 * cuál es su fortaleza y cuándo elegirla. Cada variante enlaza con su sala.
 */
const FILAS = [
  {
    variante: 'Lloyd',
    sala: '#sala-lloyd',
    actualizacion: 'Por lotes, tras asignar todos los puntos',
    fortaleza: 'Simplicidad; el más eficiente por iteración',
    debilidad: 'Necesita más iteraciones; sensible a la inicialización',
    cuando: 'Caso general, con datos estáticos',
  },
  {
    variante: 'MacQueen',
    sala: '#sala-macqueen',
    actualizacion: 'Tras cada punto, con la media incremental',
    fortaleza: 'Converge en menos pasadas; procesa datos según llegan',
    debilidad: 'Más cálculo por iteración; sensible al orden de llegada',
    cuando: 'Datos que llegan en flujo continuo',
  },
  {
    variante: 'Hartigan-Wong',
    sala: '#sala-hartigan',
    actualizacion: 'Local, punto a punto, solo si reduce la inercia',
    fortaleza: 'Escapa mejor de los mínimos locales; menos iteraciones',
    debilidad: 'Más complejo de implementar',
    cuando: 'Cuando la calidad del agrupamiento es prioritaria',
  },
  {
    variante: 'Elkan',
    sala: '#sala-elkan',
    actualizacion: 'Por lotes, con el mismo resultado que Lloyd',
    fortaleza: 'Muchos menos cálculos de distancia; escalable',
    debilidad: 'Más complejo; sensible a la inicialización',
    cuando: 'Datasets grandes donde el coste importa',
  },
  {
    variante: 'Fuzzy C-Means',
    sala: '#sala-fuzzy',
    actualizacion: 'Media ponderada por el grado de pertenencia',
    fortaleza: 'Grupos solapados; robusto ante ruido y atípicos',
    debilidad: 'Más costoso; elegir k y m requiere criterio',
    cuando: 'Cuando los límites entre grupos no están claros',
  },
];
---

<section class="section" id="guia" aria-labelledby="guia-titulo">
  <div class="prose reveal">
    <h2 id="guia-titulo">Guía de decisión</h2>
    <p>
      La pregunta del principio ya tiene respuesta: existen cinco versiones
      porque <strong>ninguna es superior en todos los casos</strong>. Cada una
      asume un compromiso distinto entre simplicidad, coste de cálculo,
      sensibilidad al orden y rigidez de la asignación. Son las mismas ideas
      que se aplican en problemas reales como la compresión de imágenes, la
      segmentación de clientes o el diagnóstico médico.
    </p>
  </div>

  <div class="lab reveal">
    <div class="panel tabla-wrap">
      <table>
        <colgroup>
          <col class="c-variante" />
          <col class="c-actualizacion" />
          <col class="c-fortaleza" />
          <col class="c-cambio" />
          <col class="c-cuando" />
        </colgroup>
        <thead>
          <tr>
            <th scope="col">variante</th>
            <th scope="col">actualización de centroides</th>
            <th scope="col">fortaleza</th>
            <th scope="col">a cambio</th>
            <th scope="col">cuándo elegirla</th>
          </tr>
        </thead>
        <tbody>
          {
            FILAS.map((f) => (
              <tr>
                <th scope="row">
                  <a href={f.sala}>{f.variante}</a>
                </th>
                <td>{f.actualizacion}</td>
                <td>{f.fortaleza}</td>
                <td>{f.debilidad}</td>
                <td>{f.cuando}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="caption tabla-nota">
      Resumen del Tema 3. Cada variante enlaza con su sala interactiva para
      volver a comprobarlo.
    </p>
  </div>
</section>

<style>
  .tabla-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
    font-size: 0.93rem;
    line-height: 1.45;
    table-layout: fixed;
  }

  col.c-variante { width: 15%; }
  col.c-actualizacion { width: 24%; }
  col.c-fortaleza { width: 23%; }
  col.c-cambio { width: 19%; }
  col.c-cuando { width: 19%; }

  thead th {
    text-align: left;
    font-size: 0.7rem;
    font-weight: 650;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--ink-soft);
    padding: 14px 18px;
    border-bottom: 1px solid var(--line);
    vertical-align: bottom;
  }

  tbody th,
  tbody td {
    text-align: left;
    vertical-align: top;
    padding: 16px 18px;
    border-bottom: 1px solid var(--line);
  }

  tbody tr:last-child th,
  tbody tr:last-child td {
    border-bottom: none;
  }

  tbody th {
    font-weight: 650;
  }

  tbody th a {
    color: var(--accent);
    text-decoration: none;
  }

  tbody th a:hover,
  tbody th a:focus-visible {
    text-decoration: underline;
  }

  tbody tr:hover {
    background: rgb(45 91 255 / 0.03);
  }

  .tabla-nota {
    margin-block-start: 12px;
  }
</style>
