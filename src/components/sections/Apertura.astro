---
/**
 * Sección 0 — Apertura. Portada limpísima con una única animación de fondo:
 * puntos que viajan hasta agruparse, se dispersan y vuelven a agruparse en
 * bucle lento. La palabra "cinco" lleva los colores de los clústeres.
 */
---

<header class="hero" id="apertura">
  <canvas aria-hidden="true"></canvas>
  <div class="social">
    <a
      href="https://github.com/AlexSaiz222"
      target="_blank"
      rel="noopener"
      aria-label="GitHub de Alejandro Saiz"
    >
      <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
      </svg>
    </a>
    <a
      href="https://www.linkedin.com/in/alejandrosaizgarc%C3%ADa"
      target="_blank"
      rel="noopener"
      aria-label="LinkedIn de Alejandro Saiz"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"/>
      </svg>
    </a>
  </div>
  <div class="prose">
    <p class="kicker">Explora K-Means de forma interactiva.</p>
    <h1>
      Cinco implementaciones para comprender el comportamiento de <span class="cinco" translate="no"
        ><span class="l1">K</span><span class="l2">-</span><span class="l3">M</span><span
          class="l4">e</span><span class="l5">a</span><span class="l1">n</span><span class="l2">s</span></span>.
    </h1>
    <p class="sub">
      K-Means parece sencillo: inicializar centroides y asignar cada punto al más cercano. Sin embargo, pequeñas variaciones en su implementación pueden producir comportamientos muy diferentes. Experimenta con los datos, modifica los centroides y observa cómo cambia el proceso de agrupamiento.
    </p>
    <div class="scroll-hint caption">
      <span>desliza para empezar</span>
      <span class="scroll-line" aria-hidden="true"></span>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 96svh;
    display: grid;
    align-content: center;
    padding-block: 96px;
    overflow: hidden;
    content-visibility: auto;
    contain-intrinsic-size: auto none auto 800px;
  }

  .hero canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.6;
    /* despeja la zona del titular sin ocultar la animación */
    -webkit-mask-image: radial-gradient(
      ellipse 58% 52% at 46% 50%,
      transparent 24%,
      #000 68%
    );
    mask-image: radial-gradient(ellipse 58% 52% at 46% 50%, transparent 24%, #000 68%);
  }

  /* enlaces del autor, discretos en la esquina superior derecha */
  .social {
    position: absolute;
    top: 22px;
    right: 26px;
    z-index: 3;
    display: flex;
    gap: 6px;
  }

  .social a {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    color: var(--ink-soft);
    transition: color 150ms ease;
  }

  .social a:hover {
    color: var(--accent);
  }

  .social a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .hero .prose {
    position: relative;
    text-align: center;
    max-width: 72ch;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .kicker {
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-block-end: 24px;
    font-weight: 500;
  }

  h1 {
    margin-block: 0;
    font-size: clamp(2rem, 5.5vw, 3.8rem);
    line-height: 1.15;
    font-weight: 800;
    text-wrap: balance;
  }

  .cinco .l1 { color: var(--c1); }
  .cinco .l2 { color: var(--c2); }
  .cinco .l3 { color: var(--c3); }
  .cinco .l4 { color: var(--c4); }
  .cinco .l5 { color: var(--c5); }

  .sub {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--ink-soft);
    max-width: 52ch;
    margin-block-start: 28px;
    line-height: 1.6;
    text-wrap: balance;
  }

  .scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin-block-start: 80px;
  }

  .scroll-line {
    display: inline-block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--ink-soft), transparent);
    transform-origin: top center;
  }

  @media (prefers-reduced-motion: no-preference) {
    .kicker,
    h1,
    .sub,
    .scroll-hint {
      animation: hero-in 700ms cubic-bezier(0.22, 1, 0.36, 1) backwards;
    }

    h1 { animation-delay: 90ms; }
    .sub { animation-delay: 200ms; }
    .scroll-hint { animation-delay: 340ms; }

    .scroll-line {
      animation: scroll-pulse 2600ms ease-in-out 1200ms infinite;
    }

    @keyframes hero-in {
      from {
        opacity: 0;
        translate: 0 18px;
      }
    }

    @keyframes scroll-pulse {
      0%, 100% { transform: scaleY(0.35); opacity: 0.5; }
      50% { transform: scaleY(1); opacity: 1; }
    }
  }
</style>

<script>
  // Animación decorativa: los puntos VIAJAN hasta formar grupos, se dispersan
  // y vuelven a agruparse. No es K-Means (eso vive en los labs); es su promesa.
  const root = document.getElementById('apertura')!;
  const canvas = root.querySelector('canvas')!;
  const ctx = canvas.getContext('2d')!;
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  const cs = getComputedStyle(canvas);
  const FALLBACK = ['#2D5BFF', '#FF7A3D', '#12B886', '#E64980', '#F2B705'];
  const palette = FALLBACK.map((fb, i) => cs.getPropertyValue(`--c${i + 1}`).trim() || fb).map(
    (hex) => {
      const h = hex.replace('#', '');
      return [parseInt(h.slice(0, 2), 16), parseInt(h.slice(2, 4), 16), parseInt(h.slice(4, 6), 16)];
    },
  );
  const NEUTRAL = [176, 176, 170];

  let w = 0;
  let h = 0;
  const ro = new ResizeObserver(() => {
    const rect = canvas.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    w = rect.width;
    h = rect.height;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(h * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    if (reduced) paint();
  });
  ro.observe(canvas);

  const N = 190;
  interface Dot {
    x: number;
    y: number;
    tx: number;
    ty: number;
    r: number;
    c: number[];
    tc: number[];
  }
  const dots: Dot[] = Array.from({ length: N }, () => ({
    x: Math.random(),
    y: Math.random(),
    tx: 0,
    ty: 0,
    r: 3.5 + Math.random() * 2.5,
    c: [...NEUTRAL],
    tc: [...NEUTRAL],
  }));

  const gauss = () =>
    (Math.random() + Math.random() + Math.random() + Math.random() - 2) / 2;

  /** Nuevos destinos: grupos amplios repartidos hacia los bordes del lienzo. */
  function gather() {
    const k = 4 + Math.floor(Math.random() * 3);
    const centers = Array.from({ length: k }, (_, j) => {
      const angle = (j / k) * Math.PI * 2 + Math.random() * 0.9;
      const radius = 0.3 + Math.random() * 0.2;
      let x = 0.5 + Math.cos(angle) * radius * 1.3;
      let y = 0.5 + Math.sin(angle) * radius;
      // la columna del texto queda libre: los grupos viven en los laterales
      if (x > 0.26 && x < 0.66 && y > 0.06 && y < 0.9) {
        x = x < 0.46 ? 0.14 + Math.random() * 0.08 : 0.76 + Math.random() * 0.08;
      }
      // y el centro entero cabe en el lienzo, sin aplastarse contra el borde
      x = Math.min(0.88, Math.max(0.12, x));
      y = Math.min(0.9, Math.max(0.1, y));
      return {
        x,
        y,
        // dispersión propia por grupo: unos compactos, otros abiertos
        spread: 0.09 + Math.random() * 0.05,
        color: palette[j % palette.length]!,
      };
    });
    for (const d of dots) {
      const g = centers[Math.floor(Math.random() * k)]!;
      d.tx = Math.min(0.98, Math.max(0.02, g.x + gauss() * g.spread * 1.25));
      d.ty = Math.min(0.96, Math.max(0.04, g.y + gauss() * g.spread));
      d.tc = g.color;
    }
  }

  /** Dispersión: los puntos pierden su grupo y su color. */
  function scatter() {
    for (const d of dots) {
      d.tx = Math.random();
      d.ty = Math.random();
      d.tc = NEUTRAL;
    }
  }

  function paint() {
    ctx.clearRect(0, 0, w, h);
    for (const d of dots) {
      ctx.beginPath();
      ctx.arc(d.x * w, d.y * h, d.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgb(${d.c[0]! | 0} ${d.c[1]! | 0} ${d.c[2]! | 0} / 0.85)`;
      ctx.fill();
    }
  }

  // ciclo: agrupar (0 ms) → dispersar (7200 ms) → siguiente ronda (10600 ms)
  let raf = 0;
  let last = 0;
  let elapsed = 0;
  let phase: 'gather' | 'scatter' = 'gather';
  let running = false;

  function tick(now: number) {
    const dt = Math.min(64, now - last);
    last = now;
    elapsed += dt;
    if (phase === 'gather' && elapsed > 7200) {
      phase = 'scatter';
      scatter();
    } else if (phase === 'scatter' && elapsed > 10600) {
      phase = 'gather';
      elapsed = 0;
      gather();
    }
    // aproximación exponencial: llegada suave, sin rebotes
    const a = 1 - Math.exp(-dt / 950);
    for (const d of dots) {
      d.x += (d.tx - d.x) * a;
      d.y += (d.ty - d.y) * a;
      for (let i = 0; i < 3; i++) d.c[i]! += (d.tc[i]! - d.c[i]!) * a;
    }
    paint();
    raf = requestAnimationFrame(tick);
  }

  function start() {
    if (running || reduced) return;
    running = true;
    last = performance.now();
    raf = requestAnimationFrame(tick);
  }

  function stop() {
    running = false;
    cancelAnimationFrame(raf);
  }

  gather();
  if (reduced) {
    // sin animación: mostrar los grupos ya formados, quietos
    for (const d of dots) {
      d.x = d.tx;
      d.y = d.ty;
      d.c = [...d.tc];
    }
    paint();
  } else {
    start();
    // solo anima mientras la portada se renderiza y la pestaña está visible
    root.addEventListener('contentvisibilityautostatechange', (ev) => {
      (ev as ContentVisibilityAutoStateChangeEvent).skipped ? stop() : start();
    });
    document.addEventListener('visibilitychange', () => {
      document.hidden ? stop() : start();
    });
  }
</script>
