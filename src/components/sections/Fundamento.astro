<style>
  /* el texto acompaña al diagrama: misma columna, alineado a su borde */
  .intro {
    max-width: 860px;
    margin-inline: auto;
    padding-inline: 24px;
    margin-block-end: 48px;
  }

  .intro p {
    max-width: 70ch;
  }

  .ciclo {
    margin: 0;
  }

  .fases {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 14px;
    align-items: stretch;
  }

  .fase {
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 14px 16px 12px;
  }

  .fase svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .fase-titulo {
    margin: 12px 0 4px;
    font-weight: 650;
    font-size: 0.95rem;
  }

  .fase-num {
    display: inline-block;
    margin-right: 8px;
    padding: 0 7px;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  .fase .caption {
    margin: 0;
  }

  .flecha {
    align-self: center;
    color: var(--ink-soft);
    font-size: 1.3rem;
  }

  .ciclo-nota {
    margin-block-start: 16px;
    max-width: 78ch;
  }

  @media (max-width: 720px) {
    .fases {
      grid-template-columns: 1fr;
    }

    .flecha {
      justify-self: center;
      rotate: 90deg;
    }
  }
</style>
