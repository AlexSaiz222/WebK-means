---
/**
 * Sección 3 — La arena comparativa. El clímax: las cinco variantes corriendo
 * en paralelo sobre el mismo dataset y la misma semilla, con métricas vivas y
 * selector de forma de datos para ver dónde cada una brilla o se rompe.
 */
const VARIANTES = ['Lloyd', 'MacQueen', 'Hartigan-Wong', 'Elkan', 'Fuzzy'];
---

<section class="section" id="arena" aria-labelledby="arena-titulo">
  <div class="prose reveal">
    <h2 id="arena-titulo">La arena</h2>
    <p>
      Ya conoces las cinco personalidades. Ahora, en igualdad de condiciones:
      <strong>los mismos datos, la misma semilla</strong>, las cinco a la vez.
      Observa quién llega antes, quién calcula menos y quién agrupa mejor, y
      cómo la respuesta cambia según la <em>forma</em> de los datos.
    </p>
    <p>
      Prueba las <em>lunas</em>: ninguna variante las separa bien. Es el
      recordatorio honesto de que las cinco comparten el mismo límite, porque
      todas buscan grupos convexos alrededor de un centro.
    </p>
  </div>

  <div class="arena-lab reveal">
    <div class="controls">
      <span class="field">datos:</span>
      <button class="btn shape" data-shape="blobs" aria-pressed="true">redondos</button>
      <button class="btn shape" data-shape="aniso" aria-pressed="false">alargados</button>
      <button class="btn shape" data-shape="densidades" aria-pressed="false">densidades desiguales</button>
      <button class="btn shape" data-shape="lunas" aria-pressed="false">lunas</button>
    </div>
    <div class="grid">
      {
        VARIANTES.map((name, i) => (
          <figure class="cell">
            <figcaption class="caption">{name}</figcaption>
            <canvas data-v={i} aria-label={`${name} sobre el dataset seleccionado`} />
            <dl class="mini">
              <div>
                <dt>it</dt>
                <dd data-m={`it-${i}`}>0</dd>
              </div>
              <div>
                <dt>dist</dt>
                <dd data-m={`dist-${i}`}>0</dd>
              </div>
              <div>
                <dt>Inercia</dt>
                <dd data-m={`sse-${i}`}>·</dd>
              </div>
            </dl>
          </figure>
        ))
      }
    </div>
    <div class="controls">
      <button class="btn btn-primary" data-action="play">reproducir</button>
      <button class="btn" data-action="step">paso a paso</button>
      <button class="btn" data-action="replay">misma semilla</button>
      <button class="btn" data-action="reshuffle">rebarajar</button>
      <span class="field">semilla: <output data-out="seed">·</output></span>
    </div>
  </div>
</section>

<style>
  .arena-lab {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 24px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin-block: 8px;
  }

  .cell {
    margin: 0;
  }

  .cell figcaption {
    margin-block-end: 6px;
  }

  .cell canvas {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: var(--surface);
    border: 1px solid var(--line);
  }

  .mini {
    display: flex;
    gap: 14px;
    margin: 8px 0 0;
    font-size: 0.8rem;
  }

  .mini div {
    display: flex;
    gap: 4px;
  }

  .mini dt {
    color: var(--ink-soft);
  }

  .mini dd {
    margin: 0;
    font-weight: 650;
    font-variant-numeric: tabular-nums;
  }

  .shape[aria-pressed='true'] {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>

<script>
  import type { Clusterer, Point } from '../../lib/algorithms/types.ts';
  import { Lloyd } from '../../lib/algorithms/lloyd.ts';
  import { MacQueen } from '../../lib/algorithms/macqueen.ts';
  import { HartiganWong } from '../../lib/algorithms/hartigan-wong.ts';
  import { Elkan } from '../../lib/algorithms/elkan.ts';
  import { Fuzzy } from '../../lib/algorithms/fuzzy.ts';
  import { blobs, anisotropic, unevenDensities, moons } from '../../lib/data/datasets.ts';
  import { CanvasRenderer } from '../../lib/sim/renderer.ts';

  const root = document.getElementById('arena')!;
  const btn = (a: string) => root.querySelector<HTMLButtonElement>(`[data-action="${a}"]`)!;
  const metric = (n: string) => root.querySelector<HTMLElement>(`[data-m="${n}"]`)!;

  const SHAPES: Record<string, { gen: (seed: number, n: number) => Point[]; k: number }> = {
    blobs: { gen: blobs, k: 3 },
    aniso: { gen: anisotropic, k: 3 },
    densidades: { gen: unevenDensities, k: 3 },
    lunas: { gen: moons, k: 2 },
  };

  const clusterers: Clusterer[] = [
    new Lloyd(),
    new MacQueen(),
    new HartiganWong(),
    new Elkan(),
    new Fuzzy(),
  ];
  const renderers = [...root.querySelectorAll('canvas')].map((c) => new CanvasRenderer(c));

  const fmt = new Intl.NumberFormat('es-ES');
  let shape = 'blobs';
  let seed = 3;
  let data: Point[] = [];
  let playing = false;
  let timer: ReturnType<typeof setTimeout> | null = null;

  const allConverged = () => clusterers.every((c) => c.converged);

  function refresh() {
    clusterers.forEach((c, i) => {
      renderers[i]!.setState({
        points: data,
        labels: c.labels,
        centroids: c.centroids,
        memberships: c.memberships,
      });
      metric(`it-${i}`).textContent = String(c.metrics.iteration);
      metric(`dist-${i}`).textContent = fmt.format(c.metrics.distanceComputations);
      metric(`sse-${i}`).textContent = Number.isNaN(c.metrics.inertia)
        ? '·'
        : c.metrics.inertia.toFixed(3);
    });
    btn('play').textContent = playing ? 'pausar' : 'reproducir';
    const done = allConverged();
    btn('play').disabled = done;
    btn('step').disabled = done;
    root.querySelector('[data-out="seed"]')!.textContent = String(seed);
  }

  /** Una iteración de cada variante aún no convergida, a la vez. */
  function step() {
    for (const c of clusterers) if (!c.converged) c.step();
    refresh();
  }

  function stop() {
    playing = false;
    if (timer) clearTimeout(timer);
    timer = null;
    refresh();
  }

  function play() {
    if (playing || allConverged()) return;
    playing = true;
    const loop = () => {
      if (!playing) return;
      step();
      if (allConverged()) stop();
      else timer = setTimeout(loop, 550);
    };
    loop();
  }

  /** Reinicia las cinco con la semilla actual: comparación justa. */
  function reset() {
    stop();
    const { gen, k } = SHAPES[shape]!;
    data = gen(seed * 7 + 1, 200);
    for (const c of clusterers) c.init(data, k, seed);
    refresh();
  }

  btn('step').addEventListener('click', () => {
    stop();
    step();
  });
  btn('play').addEventListener('click', () => (playing ? stop() : play()));
  btn('replay').addEventListener('click', reset);
  btn('reshuffle').addEventListener('click', () => {
    seed++;
    reset();
  });

  for (const b of root.querySelectorAll<HTMLButtonElement>('.shape')) {
    b.addEventListener('click', () => {
      shape = b.dataset.shape!;
      for (const other of root.querySelectorAll('.shape')) {
        other.setAttribute('aria-pressed', String(other === b));
      }
      reset();
    });
  }

  root.addEventListener('contentvisibilityautostatechange', (ev) => {
    if ((ev as ContentVisibilityAutoStateChangeEvent).skipped) stop();
  });

  reset();
</script>
