---
/**
 * Sala 2.4 — Elkan: aceleración por la desigualdad triangular. Produce el
 * mismo resultado que Lloyd; la diferencia se muestra con dos contadores de
 * distancias en paralelo y una ilustración de la desigualdad triangular.
 */
---

<section class="section" id="sala-elkan" aria-labelledby="elkan-titulo">
  <div class="prose reveal">
    <h2 id="elkan-titulo">Elkan: aceleración por la desigualdad triangular</h2>
    <p>
      Elkan produce <strong>exactamente el mismo resultado</strong> que Lloyd;
      su ventaja está en el coste computacional. Mantiene límites superior e
      inferior de la distancia de cada punto a los centroides y aplica la
      <strong>desigualdad triangular</strong> para descartar centroides
      <em>sin llegar a medirlos</em>; cada vez que los centroides se mueven,
      los límites se actualizan para minimizar los cálculos futuros. El
      resultado es eficiencia y <strong>escalabilidad</strong> en datasets
      grandes, a cambio de una implementación más compleja y de la misma
      sensibilidad a la inicialización de todo K-Means. Es la aceleración que
      usan librerías como scikit-learn, por ejemplo al comprimir una imagen
      reduciendo su paleta a <em>k</em> colores.
    </p>
  </div>

  <div class="lab reveal">
    <div class="panel">
      <div class="controls toolbar">
        <div class="seg" role="group" aria-label="forma de los datos">
          <button class="seg-btn" data-shape="redondos" aria-pressed="true">redondos</button>
          <button class="seg-btn" data-shape="alargados" aria-pressed="false">alargados</button>
          <button class="seg-btn" data-shape="desiguales" aria-pressed="false">desiguales</button>
          <button class="seg-btn" data-shape="lunas" aria-pressed="false">lunas</button>
        </div>
        <button class="btn" data-action="regen">otra muestra</button>
        <label class="field">
          k = <output data-out="k">4</output>
          <input type="range" min="2" max="6" step="1" value="4" data-in="k" aria-label="número de grupos k" />
        </label>
      </div>
      <div class="race">
        <figure>
          <figcaption class="caption">Lloyd</figcaption>
          <canvas data-canvas="lloyd" aria-label="Lloyd sobre los datos de la comparación"></canvas>
        </figure>
        <figure>
          <figcaption class="caption">Elkan</figcaption>
          <canvas data-canvas="elkan" aria-label="Elkan sobre los mismos datos y semilla"></canvas>
        </figure>
        <p class="hint" data-hint>arrastra puntos o centroides en cualquiera de los lienzos · clic para añadir</p>
      </div>
      <div class="controls timeline">
        <button class="btn btn-primary" data-action="play">reproducir</button>
        <button class="btn arrow" data-action="back" aria-label="fase anterior">←</button>
        <input
          type="range"
          min="0"
          max="0"
          step="1"
          value="0"
          data-in="pos"
          aria-label="posición en la ejecución"
        />
        <button class="btn arrow" data-action="step" aria-label="fase siguiente">→</button>
        <output class="caption" data-out="pos-label">paso 0 de 0</output>
        <button class="btn" data-action="reset">reiniciar</button>
      </div>
      <div class="narration-box">
        <span class="phase-chip" data-out="phase">inicio</span>
        <p class="narration" data-out="narration">·</p>
      </div>
      <dl class="metrics">
        <div class="metric">
          <dt>distancias · Lloyd</dt>
          <dd data-out="lloyd-comps">0</dd>
        </div>
        <div class="metric">
          <dt>distancias · Elkan</dt>
          <dd data-out="elkan-comps">0</dd>
        </div>
        <div class="metric">
          <dt>ahorro</dt>
          <dd data-out="saving">·</dd>
        </div>
        <div class="metric">
          <dt>mismas etiquetas</dt>
          <dd data-out="same">·</dd>
        </div>
        <div class="metric">
          <dt>estado</dt>
          <dd data-out="status">listo</dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="prose reveal">
    <figure class="triangulo">
      <svg viewBox="0 0 420 230" role="img" aria-label="Ilustración de la desigualdad triangular: si la distancia entre centroides es al menos el doble de la distancia conocida al centroide asignado, el otro centroide no puede estar más cerca y no hace falta medirlo.">
        <line x1="70" y1="185" x2="270" y2="185" stroke="#1A1A1A" stroke-width="1.5" />
        <line x1="270" y1="185" x2="330" y2="45" stroke="#1A1A1A" stroke-width="1.5" />
        <line x1="70" y1="185" x2="330" y2="45" stroke="#6B6B6B" stroke-width="1.5" stroke-dasharray="6 5" />
        <circle cx="70" cy="185" r="5" fill="#1A1A1A" />
        <circle cx="270" cy="185" r="8" fill="#FFFFFF" stroke="#2D5BFF" stroke-width="2.5" />
        <circle cx="330" cy="45" r="8" fill="#FFFFFF" stroke="#FF7A3D" stroke-width="2.5" />
        <text x="58" y="210" font-size="15" fill="#1A1A1A">x</text>
        <text x="248" y="212" font-size="15" fill="#2D5BFF">c asignado</text>
        <text x="342" y="42" font-size="15" fill="#FF7A3D">c otro</text>
        <text x="155" y="178" font-size="14" fill="#1A1A1A">u(x)</text>
        <text x="308" y="128" font-size="14" fill="#1A1A1A">d(c, c′)</text>
        <text x="150" y="100" font-size="14" fill="#6B6B6B">¿hace falta medirla?</text>
      </svg>
      <figcaption class="caption">
        La desigualdad triangular dice que la línea discontinua no puede medir
        menos que <em>d(c, c′) − u(x)</em>. Si <em>d(c, c′) ≥ 2 · u(x)</em>, el
        otro centroide queda descartado sin medir nada: ese es el ahorro.
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .race {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: 16px;
    /* la pista se posiciona respecto a la zona de lienzos, no al panel */
    position: relative;
  }

  .race .hint {
    bottom: 22px;
    right: 26px;
  }

  .race figure {
    margin: 0;
  }

  .race canvas {
    border: 1px solid var(--line);
  }

  .race figcaption {
    margin-block-end: 8px;
  }

  @media (max-width: 640px) {
    .race {
      grid-template-columns: 1fr;
    }
  }

  .triangulo {
    margin: 48px 0 0;
  }

  .triangulo svg {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
    margin-inline: auto;
  }
</style>

<script>
  import { Lloyd } from '../../lib/algorithms/lloyd.ts';
  import { Elkan } from '../../lib/algorithms/elkan.ts';

  import type { Point } from '../../lib/algorithms/types.ts';
  import { blobs, anisotropic, unevenDensities, moons } from '../../lib/data/datasets.ts';
  import { CanvasRenderer } from '../../lib/sim/renderer.ts';

  const root = document.getElementById('sala-elkan')!;
  const out = (n: string) => root.querySelector<HTMLElement>(`[data-out="${n}"]`)!;
  const btn = (a: string) => root.querySelector<HTMLButtonElement>(`[data-action="${a}"]`)!;
  const hint = root.querySelector<HTMLElement>('[data-hint]')!;
  const posInput = root.querySelector<HTMLInputElement>('[data-in="pos"]')!;
  const kInput = root.querySelector<HTMLInputElement>('[data-in="k"]')!;

  const SHAPES: Record<string, (seed: number, n: number) => Point[]> = {
    redondos: blobs,
    alargados: anisotropic,
    desiguales: unevenDensities,
    lunas: moons,
  };

  const seed = 4;
  let shape = 'redondos';
  let dataSeed = 41;
  let k = 4;
  let points = SHAPES[shape]!(dataSeed, 200);

  const lloyd = new Lloyd();
  const elkan = new Elkan();
  const cLloyd = root.querySelector<HTMLCanvasElement>('[data-canvas="lloyd"]')!;
  const cElkan = root.querySelector<HTMLCanvasElement>('[data-canvas="elkan"]')!;
  const rLloyd = new CanvasRenderer(cLloyd);
  const rElkan = new CanvasRenderer(cElkan);
  const accent =
    getComputedStyle(cLloyd).getPropertyValue('--accent').trim() || '#2D5BFF';

  const fmt = new Intl.NumberFormat('es-ES');

  // ---- historial ----
  interface HistoryFrame {
    iteration: number;
    lloydLabels: number[];
    lloydCentroids: Point[];
    lloydDists: number;
    elkanLabels: number[];
    elkanCentroids: Point[];
    elkanDists: number;
    inertiaVal: number;
    converged: boolean;
  }

  let history: HistoryFrame[] = [];
  let pos = 0;
  const current = () => history[pos]!;
  const last = () => history[history.length - 1]!;

  function snapshot(): HistoryFrame {
    return {
      iteration: lloyd.metrics.iteration,
      lloydLabels: [...lloyd.labels],
      lloydCentroids: lloyd.centroids.map(c => ({ ...c })),
      lloydDists: lloyd.metrics.distanceComputations,
      elkanLabels: [...elkan.labels],
      elkanCentroids: elkan.centroids.map(c => ({ ...c })),
      elkanDists: elkan.metrics.distanceComputations,
      inertiaVal: lloyd.metrics.inertia,
      converged: lloyd.converged && elkan.converged,
    };
  }

  function computeRun() {
    let guard = 0;
    while (!(lloyd.converged && elkan.converged) && guard++ < 80) {
      if (!lloyd.converged) lloyd.step();
      if (!elkan.converged) elkan.step();
      history.push(snapshot());
    }
  }

  function narration(): string {
    const s = current();
    if (s.iteration === 0) {
      return (
        'Ambos algoritmos parten de la misma inicialización (k-means++). Pulsa <strong>reproducir</strong> o <strong>→</strong> ' +
        'para verlos avanzar en paralelo: mismas etiquetas, distinto número de cálculos.'
      );
    }
    const saving = s.lloydDists > 0
      ? Math.round((1 - s.elkanDists / s.lloydDists) * 100)
      : 0;
    const conv = s.converged
      ? ' <strong>Convergido.</strong>'
      : '';
    return (
      `Lloyd ha calculado <strong>${fmt.format(s.lloydDists)}</strong> distancias y ` +
      `Elkan <strong>${fmt.format(s.elkanDists)}</strong>, un ahorro del ${saving} %.${conv}`
    );
  }

  function display(animate = true) {
    const s = current();
    rLloyd.setState({ points, labels: s.lloydLabels, centroids: s.lloydCentroids }, animate);
    rElkan.setState({ points, labels: s.elkanLabels, centroids: s.elkanCentroids }, animate);

    const total = history.length - 1;
    posInput.max = String(total);
    posInput.value = String(pos);
    posInput.style.setProperty('--p', `${total > 0 ? (pos / total) * 100 : 0}%`);
    out('pos-label').textContent = `paso ${pos} de ${total}`;
    out('phase').textContent = s.iteration > 0 ? `iteración ${s.iteration}` : 'inicio';
    out('narration').innerHTML = narration();

    out('lloyd-comps').textContent = fmt.format(s.lloydDists);
    out('elkan-comps').textContent = fmt.format(s.elkanDists);
    out('saving').textContent = s.lloydDists > 0
      ? `${Math.round((1 - s.elkanDists / s.lloydDists) * 100)} %`
      : '·';
    out('same').textContent = s.iteration === 0
      ? '·'
      : s.lloydLabels.every((l, i) => l === s.elkanLabels[i])
        ? 'sí'
        : 'no';
    out('status').textContent =
      s.converged && pos === history.length - 1
        ? 'convergido'
        : playing
          ? 'en marcha'
          : pos === 0 && s.iteration === 0
            ? 'listo'
            : pos < history.length - 1
              ? 'repasando'
              : 'pausado';

    const atEnd = pos === history.length - 1 && last().converged;
    btn('play').textContent = playing ? 'pausar' : 'reproducir';
    btn('play').disabled = atEnd;
    btn('step').disabled = atEnd;
    btn('back').disabled = pos === 0;
  }

  function forward(animate = true): boolean {
    if (pos >= history.length - 1) return false;
    pos++;
    display(animate);
    return true;
  }

  function back() {
    if (pos === 0) return;
    pos--;
    display();
  }

  // ---- reproducir ----
  let playing = false;
  let timer: ReturnType<typeof setTimeout> | null = null;

  function stopPlay() {
    playing = false;
    if (timer) clearTimeout(timer);
    timer = null;
  }

  function play() {
    if (playing) return;
    playing = true;
    const loop = () => {
      if (!playing) return;
      if (forward()) timer = setTimeout(loop, 700);
      else stopPlay();
      display();
    };
    loop();
  }

  function reinit(startCentroids?: Point[]) {
    stopPlay();
    lloyd.init(points, k, seed + dataSeed);
    elkan.init(points, k, seed + dataSeed);
    // arranque manual (centroide arrastrado): ambos parten de los MISMOS
    // centroides, que es la condición para que Elkan == Lloyd
    if (startCentroids) {
      lloyd.centroids = startCentroids.map((c) => ({ ...c }));
      elkan.centroids = startCentroids.map((c) => ({ ...c }));
    }
    history = [snapshot()];
    pos = 0;
    computeRun();
    display(false);
  }

  // ---- controles ----
  btn('play').addEventListener('click', () => {
    if (playing) { stopPlay(); display(); }
    else play();
  });
  btn('step').addEventListener('click', () => { stopPlay(); forward(); });
  btn('back').addEventListener('click', () => { stopPlay(); back(); });
  btn('reset').addEventListener('click', () => reinit());
  btn('regen').addEventListener('click', () => {
    dataSeed++;
    points = SHAPES[shape]!(dataSeed, 200);
    reinit();
  });

  posInput.addEventListener('input', () => {
    stopPlay();
    pos = Number(posInput.value);
    display(false);
  });

  kInput.addEventListener('input', () => {
    k = Number(kInput.value);
    out('k').textContent = kInput.value;
    reinit();
  });

  for (const b of root.querySelectorAll<HTMLButtonElement>('.seg-btn')) {
    b.addEventListener('click', () => {
      shape = b.dataset.shape!;
      for (const other of root.querySelectorAll('.seg-btn')) {
        other.setAttribute('aria-pressed', String(other === b));
      }
      points = SHAPES[shape]!(dataSeed, 200);
      reinit();
    });
  }

  // ---- teclado ----
  let inView = false;
  new IntersectionObserver(
    (entries) => { for (const e of entries) inView = e.isIntersecting; },
    { threshold: 0.25 },
  ).observe(root);

  document.addEventListener('keydown', (ev) => {
    if (!inView || (ev.key !== 'ArrowLeft' && ev.key !== 'ArrowRight')) return;
    const t = ev.target as HTMLElement;
    if (t instanceof HTMLInputElement && t !== posInput) return;
    ev.preventDefault();
    stopPlay();
    if (ev.key === 'ArrowRight') forward();
    else back();
  });

  // ---- interacción con los lienzos ----
  const clamp01 = (v: number) => Math.min(0.98, Math.max(0.02, v));
  let dragCentroid = -1;
  let dragPoint = -1;
  let hoverCentroid = -1;

  const hitCentroid = (p: Point, centroids: Point[], renderer: CanvasRenderer) => {
    const tol = renderer.pxToData(14);
    let best = -1;
    let bestD = tol * tol;
    centroids.forEach((c, j) => {
      const d = (c.x - p.x) ** 2 + (c.y - p.y) ** 2;
      if (d < bestD) { bestD = d; best = j; }
    });
    return best;
  };

  const hitPoint = (p: Point, renderer: CanvasRenderer) => {
    const tol = renderer.pxToData(11);
    let best = -1;
    let bestD = tol * tol;
    points.forEach((q, i) => {
      const d = (q.x - p.x) ** 2 + (q.y - p.y) ** 2;
      if (d < bestD) { bestD = d; best = i; }
    });
    return best;
  };

  const overlayFn = (ctx: CanvasRenderingContext2D, map: { x: (v: number) => number; y: (v: number) => number }) => {
    if (hoverCentroid >= 0) {
      const c = current().lloydCentroids[hoverCentroid];
      if (c) {
        ctx.beginPath();
        ctx.arc(map.x(c.x), map.y(c.y), 13, 0, Math.PI * 2);
        ctx.lineWidth = 2;
        ctx.strokeStyle = accent;
        ctx.stroke();
      }
    }
  };

  rLloyd.setOverlay(overlayFn);
  rElkan.setOverlay(overlayFn);

  const setupEvents = (canvas: HTMLCanvasElement, renderer: CanvasRenderer) => {
    canvas.addEventListener('pointerdown', (ev) => {
      hint.classList.add('is-hidden');
      stopPlay();
      const p = renderer.eventToData(ev);
      const cents = current().lloydCentroids;
      const cIdx = hitCentroid(p, cents, renderer);
      if (cIdx >= 0) {
        // slice history at current pos for branching
        history = history.slice(0, pos + 1);
        dragCentroid = cIdx;
        canvas.style.cursor = 'grabbing';
        try { canvas.setPointerCapture(ev.pointerId); } catch { /* puntero sintético o ya liberado */ }
        return;
      }
      const pIdx = hitPoint(p, renderer);
      if (pIdx >= 0) {
        dragPoint = pIdx;
        canvas.style.cursor = 'grabbing';
        try { canvas.setPointerCapture(ev.pointerId); } catch { /* puntero sintético o ya liberado */ }
      } else {
        points.push({ x: clamp01(p.x), y: clamp01(p.y) });
        reinit();
      }
    });

    canvas.addEventListener('pointermove', (ev) => {
      const p = renderer.eventToData(ev);
      if (dragCentroid >= 0) {
        const s = current();
        s.lloydCentroids[dragCentroid] = { x: clamp01(p.x), y: clamp01(p.y) };
        s.elkanCentroids[dragCentroid] = { x: clamp01(p.x), y: clamp01(p.y) };
        display(false);
        return;
      }
      if (dragPoint >= 0) {
        points[dragPoint] = { x: clamp01(p.x), y: clamp01(p.y) };
        display(false);
        return;
      }

      const cents = current().lloydCentroids;
      const cIdx = hitCentroid(p, cents, renderer);
      if (cIdx !== hoverCentroid) {
        hoverCentroid = cIdx;
        display(false);
      }
      canvas.style.cursor = cIdx >= 0 || hitPoint(p, renderer) >= 0 ? 'grab' : 'crosshair';
    });

    canvas.addEventListener('pointerup', () => {
      if (dragCentroid >= 0) {
        dragCentroid = -1;
        canvas.style.cursor = 'grab';
        // nueva ejecución completa desde los centroides arrastrados
        // (reinicio total porque Elkan guarda límites internos)
        reinit(current().lloydCentroids);
        return;
      }
      if (dragPoint >= 0) {
        dragPoint = -1;
        canvas.style.cursor = 'grab';
        reinit();
      }
    });

    canvas.addEventListener('pointerleave', () => {
      if (hoverCentroid >= 0) {
        hoverCentroid = -1;
        display(false);
      }
    });
  };

  setupEvents(cLloyd, rLloyd);
  setupEvents(cElkan, rElkan);

  root.addEventListener('contentvisibilityautostatechange', (ev) => {
    if ((ev as ContentVisibilityAutoStateChangeEvent).skipped) {
      stopPlay();
      display();
    }
  });

  // gancho para verificación
  (window as unknown as Record<string, unknown>).__labElkan = {
    centroids: () => current().elkanCentroids.map(c => ({ ...c })),
    pos: () => pos,
    length: () => history.length,
    points: () => points.map(p => ({ ...p })),
  };

  reinit();
</script>
