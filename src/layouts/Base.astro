---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'K-Means Explorable: un algoritmo, cinco personalidades',
  description = 'Una explicación explorable de por qué existen cinco variantes de K-Means: Lloyd, MacQueen, Hartigan-Wong, Elkan y Fuzzy.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <slot />
  </body>
</html>
