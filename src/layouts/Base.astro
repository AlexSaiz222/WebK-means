---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '5 algoritmos de K-Means explicados',
  description = 'Explicación interactiva de cinco variantes del algoritmo K-Means: Lloyd, MacQueen, Hartigan-Wong, Elkan y Fuzzy K-Means.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <meta name="theme-color" content="#FAFAF8" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={new URL(`${import.meta.env.BASE_URL.replace(/\/$/, '')}/og.png`, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <slot />
  </body>
</html>
